{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "esModuleInterop": true,
    "strict": true,
    "resolveJsonModule": true,
    "outDir": "dist",
    "declaration": true,
    "skipLibCheck": true
  },
  "include": ["./contracts", "./test", "./scripts"],
  "exclude": ["node_modules", "artifacts", "cache", "typechain-types"]
}
