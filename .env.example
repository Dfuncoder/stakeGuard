# StakeGuard Environment Variables
# Copy this file to .env.local and fill in values

# Optional: RPC URL for fetching real on-chain EigenLayer data
# NEXT_PUBLIC_RPC_URL=https://mainnet.infura.io/v3/YOUR_KEY

# Optional: Subgraph URL for EigenLayer AVS data
# NEXT_PUBLIC_EIGENLAYER_SUBGRAPH=https://api.thegraph.com/subgraphs/name/...
