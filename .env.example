# StakeGuard Environment Variables
# Copy this file to .env.local and fill in values

# ── Contract Integration (optional — enables Live Chain mode) ──────────────────
# Set these after deploying the RestakingGuard contract
# NEXT_PUBLIC_CONTRACT_ADDRESS=0xYourContractAddressHere
# NEXT_PUBLIC_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY

# ── Without these set, the app runs in Simulation Mode (fully functional) ──────
